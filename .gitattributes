# Normalize common repository text files.
* text=auto

# Keep source, docs, configs, tests, and committed fixtures deterministic.
*.py text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Generated or binary-like artifacts.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
*.parquet binary
*.zip binary
*.whl binary
*.gz binary
