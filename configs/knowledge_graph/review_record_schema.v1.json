{
  "schema_id": "knowledge_graph_review_record",
  "version": "v1",
  "description": "Minimal governance schema for documenting human review of VALI knowledge graph objects before freeze eligibility.",
  "documentation_only": true,
  "runtime_parsing_supported": false,
  "required_fields": [
    "review_id",
    "graph_id",
    "graph_version",
    "review_status",
    "reviewed_files",
    "review_checks",
    "claim_boundaries",
    "human_review_required",
    "freeze_recommendation"
  ],
  "recommended_fields": [
    "reviewer_role",
    "reviewed_at",
    "evidence_status",
    "open_items",
    "prohibited_scope_checks",
    "notes"
  ],
  "allowed_review_statuses": [
    "draft",
    "review_in_progress",
    "reviewed_with_open_items",
    "approved_for_freeze",
    "blocked",
    "rejected"
  ],
  "allowed_freeze_recommendations": [
    "not_ready",
    "ready_after_open_items",
    "approved_for_freeze",
    "blocked"
  ],
  "required_review_checks": [
    "contract_rules",
    "contract_template_applicability",
    "terminal_measure",
    "settlement_source",
    "clear_horizon",
    "market_date_bucket_mapping",
    "attention_concepts",
    "candidate_queries",
    "contamination_risks",
    "claim_boundaries"
  ],
  "claim_boundaries": [
    "review record is not empirical validation",
    "review record does not prove alpha",
    "review record does not authorize trading",
    "review record does not prove trading readiness",
    "review record does not replace contract or legal review where needed",
    "ambiguous fields must remain review_required or blocked"
  ],
  "prohibited_allowed_scope": [
    "P_flow",
    "private data",
    "proprietary order flow",
    "credentials",
    "live trading",
    "order submission"
  ]
}
